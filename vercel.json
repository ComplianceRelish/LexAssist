{
  "rewrites": [{ "source": "/(.*)", "destination": "/" }],
  "buildCommand": "cd legal_app_frontend && npm install --legacy-peer-deps && npm run build",
  "outputDirectory": "legal_app_frontend/dist",
  "framework": "vite",
  "env": {
    "VITE_BACKEND_URL": "https://lexassist-backend.onrender.com",
    "VITE_SUPABASE_URL": "https://meuyiktpkeomskqornnu.supabase.co",
    "VITE_SUPABASE_ANON_KEY": "${SUPABASE_ANON_KEY}",
    "VITE_INLEGALBERT_MODEL_PATH": "law-ai/InLegalBERT"
  },
  "github": {
    "enabled": true,
    "silent": false,
    "autoAlias": true,
    "productionBranch": "main"
  },
  "deploymentTarget": "production"
}
